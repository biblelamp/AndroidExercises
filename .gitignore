# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Intellij
*.iml
.idea/

# Keystore files — never commit these!
*.jks
*.keystore

# Keystore credentials file — never commit this!
keystore.properties

# Google services config (contains API keys)
google-services.json

# DS_Store (macOS)
.DS_Store

# Windows thumbnail cache
Thumbs.db

# Gradle wrapper (optional, keep if you want reproducible builds)
# gradle/wrapper/gradle-wrapper.jar